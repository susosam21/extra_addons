<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="crm_lead_activity_report_wizard_view_form" model="ir.ui.view">
        <field name="name">crm.lead.activity.report.wizard.form</field>
        <field name="model">crm.lead.activity.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Lead Activity Report">
                <group>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <group>
                        <field name="team_id"/>
                        <field name="user_id" domain="[('share', '=', False)]"/>
                        <field name="include_archived"/>
                    </group>
                </group>
                <footer>
                    <button name="action_generate_report" string="Generate Report" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="crm_lead_activity_report_wizard_action" model="ir.actions.act_window">
        <field name="name">Lead Activity Report</field>
        <field name="res_model">crm.lead.activity.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="crm_lead_activity_report_line_view_tree" model="ir.ui.view">
        <field name="name">crm.lead.activity.report.line.tree</field>
        <field name="model">crm.lead.activity.report.line</field>
        <field name="arch" type="xml">
            <tree create="false" edit="false" delete="false" default_order="last_interaction_at desc">
                <field name="lead_name"/>
                <field name="company_name"/>
                <field name="team_id"/>
                <field name="user_id"/>
                <field name="stage_id"/>
                <field name="lead_created_at"/>
                <field name="first_interaction_at"/>
                <field name="last_interaction_at"/>
                <field name="last_note_at"/>
                <field name="note_count"/>
                <field name="note_sentiment"/>
                <field name="days_to_first_interaction"/>
                <field name="days_since_last_note"/>
                <field name="note_analysis"/>
            </tree>
        </field>
    </record>

    <record id="crm_lead_activity_report_line_view_search" model="ir.ui.view">
        <field name="name">crm.lead.activity.report.line.search</field>
        <field name="model">crm.lead.activity.report.line</field>
        <field name="arch" type="xml">
            <search string="Lead Activity Report">
                <field name="lead_name"/>
                <field name="company_name"/>
                <field name="team_id"/>
                <field name="user_id"/>
                <field name="stage_id"/>
                <filter string="Connected" name="connected" domain="[('first_interaction_at', '!=', False)]"/>
                <filter string="No Notes" name="no_notes" domain="[('note_count', '=', 0)]"/>
                <filter string="Positive" name="positive" domain="[('note_sentiment', '=', 'positive')]"/>
                <filter string="Negative" name="negative" domain="[('note_sentiment', '=', 'negative')]"/>
                <group expand="0" string="Group By">
                    <filter string="Sales Team" name="group_team" context="{'group_by': 'team_id'}"/>
                    <filter string="Salesperson" name="group_salesperson" context="{'group_by': 'user_id'}"/>
                    <filter string="Stage" name="group_stage" context="{'group_by': 'stage_id'}"/>
                    <filter string="Sentiment" name="group_sentiment" context="{'group_by': 'note_sentiment'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="crm_lead_activity_report_line_view_pivot" model="ir.ui.view">
        <field name="name">crm.lead.activity.report.line.pivot</field>
        <field name="model">crm.lead.activity.report.line</field>
        <field name="arch" type="xml">
            <pivot string="Lead Activity Analysis">
                <field name="team_id" type="row"/>
                <field name="user_id" type="row"/>
                <field name="note_sentiment" type="col"/>
                <field name="lead_id" type="measure"/>
                <field name="note_count" type="measure"/>
                <field name="positive_note_count" type="measure"/>
                <field name="negative_note_count" type="measure"/>
                <field name="days_to_first_interaction" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="crm_lead_activity_report_line_view_graph" model="ir.ui.view">
        <field name="name">crm.lead.activity.report.line.graph</field>
        <field name="model">crm.lead.activity.report.line</field>
        <field name="arch" type="xml">
            <graph string="Lead Activity" type="bar">
                <field name="team_id"/>
                <field name="note_count" type="measure"/>
                <field name="positive_note_count" type="measure"/>
                <field name="negative_note_count" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="crm_lead_activity_report_line_action" model="ir.actions.act_window">
        <field name="name">Lead Activity Analysis</field>
        <field name="res_model">crm.lead.activity.report.line</field>
        <field name="view_mode">tree,pivot,graph</field>
        <field name="search_view_id" ref="crm_lead_activity_report_line_view_search"/>
        <field name="target">current</field>
        <field name="context">{}</field>
    </record>

    <menuitem
        id="crm_lead_activity_report_menu"
        name="Lead Activity Report"
        parent="crm.crm_menu_root"
        action="crm_lead_activity_report_wizard_action"
        sequence="95"
        groups="sales_team.group_sale_salesman"/>
</odoo>
