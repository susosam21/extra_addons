<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="crm_lead_activity_report_html" model="ir.actions.report">
        <field name="name">CRM Lead Activity HTML Report</field>
        <field name="model">crm.lead.activity.report.wizard</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">crm_lead_activity_report.crm_lead_activity_report_document</field>
        <field name="report_file">crm_lead_activity_report.crm_lead_activity_report_document</field>
        <field name="print_report_name">'Lead_Activity_Report_%s' % (object.date_to or '')</field>
    </record>

    <template id="crm_lead_activity_report_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="wizard">
                <t t-set="lines" t-value="wizard.line_ids"/>
                <t t-set="total" t-value="len(lines)"/>
                <t t-set="contacted" t-value="len(lines.filtered(lambda l: l.contacted_tag))"/>
                <t t-set="lost" t-value="len(lines.filtered(lambda l: l.lost_reason))"/>
                <t t-set="internal_notes" t-value="sum(lines.mapped('internal_note_count'))"/>

                <div class="page" style="font-family: 'Segoe UI', Arial, sans-serif; background:#f0f2f5; color:#1e293b; padding:18px;">
                    <div style="max-width:1100px; margin:0 auto;">
                        <div style="background:#0A1528; border-radius:12px; padding:24px; color:#fff; margin-bottom:18px;">
                            <h2 style="margin:0; font-size:24px;">Team Lead Activity Report</h2>
                            <p style="margin:8px 0 0 0; color:#cbd5e1; font-size:13px;">
                                Period:
                                <strong t-esc="wizard.date_from"/>
                                -
                                <strong t-esc="wizard.date_to"/>
                            </p>
                        </div>

                        <div style="display:flex; gap:12px; margin-bottom:16px;">
                            <div style="flex:1; background:#fff; border-radius:10px; padding:14px; box-shadow:0 1px 4px rgba(0,0,0,.08);">
                                <div style="font-size:28px; font-weight:800; color:#0A1528;" t-esc="total"/>
                                <div style="font-size:12px; color:#64748b;">Total Leads</div>
                            </div>
                            <div style="flex:1; background:#fff; border-radius:10px; padding:14px; box-shadow:0 1px 4px rgba(0,0,0,.08);">
                                <div style="font-size:28px; font-weight:800; color:#1d4ed8;" t-esc="contacted"/>
                                <div style="font-size:12px; color:#64748b;">Contacted Tag</div>
                            </div>
                            <div style="flex:1; background:#fff; border-radius:10px; padding:14px; box-shadow:0 1px 4px rgba(0,0,0,.08);">
                                <div style="font-size:28px; font-weight:800; color:#dc2626;" t-esc="lost"/>
                                <div style="font-size:12px; color:#64748b;">Lost Leads</div>
                            </div>
                            <div style="flex:1; background:#fff; border-radius:10px; padding:14px; box-shadow:0 1px 4px rgba(0,0,0,.08);">
                                <div style="font-size:28px; font-weight:800; color:#0f766e;" t-esc="internal_notes"/>
                                <div style="font-size:12px; color:#64748b;">Internal Log Notes</div>
                            </div>
                        </div>

                        <div style="background:#fff; border-radius:10px; padding:16px; box-shadow:0 1px 4px rgba(0,0,0,.08);">
                            <h3 style="margin:0 0 12px 0; font-size:16px; color:#0A1528;">Lead Details and Issues</h3>
                            <table style="width:100%; border-collapse:collapse; font-size:12px;">
                                <thead>
                                    <tr>
                                        <th style="text-align:left; background:#0A1528; color:#fff; padding:8px;">Lead</th>
                                        <th style="text-align:left; background:#0A1528; color:#fff; padding:8px;">Salesperson</th>
                                        <th style="text-align:left; background:#0A1528; color:#fff; padding:8px;">Connected</th>
                                        <th style="text-align:left; background:#0A1528; color:#fff; padding:8px;">Contacted Tag</th>
                                        <th style="text-align:left; background:#0A1528; color:#fff; padding:8px;">Lost Reason</th>
                                        <th style="text-align:left; background:#0A1528; color:#fff; padding:8px;">Issue Summary (Internal Notes)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="lines" t-as="line">
                                        <td style="padding:8px; border-bottom:1px solid #e2e8f0;">
                                            <div style="font-weight:700;" t-esc="line.lead_name"/>
                                            <div style="color:#64748b;" t-esc="line.company_name or '-'"/>
                                        </td>
                                        <td style="padding:8px; border-bottom:1px solid #e2e8f0;" t-esc="line.user_id.name or '-'"/>
                                        <td style="padding:8px; border-bottom:1px solid #e2e8f0;">
                                            <div>
                                                <span style="color:#0f766e; font-weight:700;">First:</span>
                                                <span t-esc="line.first_interaction_at or '-'"/>
                                            </div>
                                            <div>
                                                <span style="color:#1d4ed8; font-weight:700;">Last:</span>
                                                <span t-esc="line.last_interaction_at or '-'"/>
                                            </div>
                                        </td>
                                        <td style="padding:8px; border-bottom:1px solid #e2e8f0;">
                                            <span t-if="line.contacted_tag" style="background:#eff6ff; color:#1d4ed8; padding:2px 6px; border-radius:10px; font-weight:700;">Contacted</span>
                                            <span t-if="not line.contacted_tag" style="color:#94a3b8;">-</span>
                                            <div style="margin-top:4px; color:#64748b;" t-esc="line.tag_names or '-'"/>
                                        </td>
                                        <td style="padding:8px; border-bottom:1px solid #e2e8f0;">
                                            <span t-if="line.lost_reason" style="background:#fef2f2; color:#dc2626; padding:2px 6px; border-radius:10px; font-weight:700;" t-esc="line.lost_reason"/>
                                            <span t-if="not line.lost_reason" style="color:#94a3b8;">-</span>
                                        </td>
                                        <td style="padding:8px; border-bottom:1px solid #e2e8f0;">
                                            <div style="font-weight:600; color:#0A1528;" t-esc="line.issue_summary or line.latest_internal_note or '-'"/>
                                            <div style="margin-top:4px; color:#64748b;">Internal notes: <span t-esc="line.internal_note_count"/></div>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </t>
        </t>
    </template>
</odoo>
